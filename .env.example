# Paytm Payment Gateway - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's already in .gitignore

# Paytm Credentials (from Paytm Dashboard)
PAYTM_MID=bnFRXI03661934553961
PAYTM_MERCHANT_KEY=hE@ZFPBBDMeTa_TE
PAYTM_WEBSITE=DEFAULT
PAYTM_INDUSTRY_TYPE=Retail

# Paytm API Host
# Production: securegw.paytm.in
# Sandbox/Testing: securegw-stage.paytm.in
PAYTM_HOST=securegw.paytm.in

# Your Application URL (for callback)
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Frontend MID (same as PAYTM_MID, used in public/index.html for SDK)
# CRA uses REACT_APP_ prefix for frontend-exposed env vars
REACT_APP_PAYTM_MID=YOUR_MERCHANT_ID
