{
    "outputDirectory": "dist",
    "trailingSlash": false,
    "redirects": [
        {
            "source": "/:path*",
            "destination": "https://www.logisaar.in/:path*",
            "permanent": true,
            "has": [
                {
                    "type": "host",
                    "value": "logisaar.in"
                }
            ]
        },
        {
            "source": "/favicon.ico",
            "destination": "/favicon.png",
            "permanent": true
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.+\\.[^/]+)$",
            "dest": "/$1"
        },
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/(checkout|payment)",
            "headers": {
                "X-Robots-Tag": "noindex, nofollow"
            },
            "dest": "/index.html"
        },
        {
            "src": "/(about|services|portfolio|pricing|contact|web-development-odisha)",
            "dest": "/index.html"
        },
        {
            "src": "/services/(school-management-system|hotel-management-system|ai-lead-followup|ai-receptionist|proposal-software|qr-menu-system|travel-website|ai-automation|custom-crm)",
            "dest": "/index.html"
        },
        {
            "src": "/.*",
            "status": 404
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Credentials",
                    "value": "true"
                },
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
                }
            ]
        }
    ],
    "functions": {
        "api/paytm/initiate.ts": {
            "memory": 512,
            "maxDuration": 30
        },
        "api/paytm/callback.ts": {
            "memory": 512,
            "maxDuration": 30
        }
    }
}
