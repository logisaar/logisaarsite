{
    "outputDirectory": "dist",
    "redirects": [
        {
            "source": "/favicon.ico",
            "destination": "/favicon.png",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/",
            "destination": "/index.html"
        },
        {
            "source": "/about",
            "destination": "/index.html"
        },
        {
            "source": "/services",
            "destination": "/index.html"
        },
        {
            "source": "/portfolio",
            "destination": "/index.html"
        },
        {
            "source": "/pricing",
            "destination": "/index.html"
        },
        {
            "source": "/contact",
            "destination": "/index.html"
        },
        {
            "source": "/checkout",
            "destination": "/index.html"
        },
        {
            "source": "/payment",
            "destination": "/index.html"
        },
        {
            "source": "/web-development-odisha",
            "destination": "/index.html"
        },
        {
            "source": "/services/school-management-system",
            "destination": "/index.html"
        },
        {
            "source": "/services/hotel-management-system",
            "destination": "/index.html"
        },
        {
            "source": "/services/ai-lead-followup",
            "destination": "/index.html"
        },
        {
            "source": "/services/ai-receptionist",
            "destination": "/index.html"
        },
        {
            "source": "/services/proposal-software",
            "destination": "/index.html"
        },
        {
            "source": "/services/qr-menu-system",
            "destination": "/index.html"
        },
        {
            "source": "/services/travel-website",
            "destination": "/index.html"
        },
        {
            "source": "/services/ai-automation",
            "destination": "/index.html"
        },
        {
            "source": "/services/custom-crm",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/checkout",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/payment",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Credentials",
                    "value": "true"
                },
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
                }
            ]
        }
    ],
    "functions": {
        "api/paytm/initiate.ts": {
            "memory": 512,
            "maxDuration": 30
        },
        "api/paytm/callback.ts": {
            "memory": 512,
            "maxDuration": 30
        }
    }
}
